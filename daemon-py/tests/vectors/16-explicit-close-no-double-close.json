{
  "name": "reconciliation_after_an_explicit_close_does_not_double_close",
  "description": "An explicit idle close followed by a later suspend must not produce a second idle.",
  "steps": [
    { "op": "tick", "now": 0, "idle_ms": 0 },
    { "op": "tick", "now": 40000, "idle_ms": 0 },
    { "op": "tick", "now": 700000, "idle_ms": 700000 },
    { "op": "tick", "now": 14400000, "idle_ms": 999999, "mono_elapsed_ms": 15000 }
  ],
  "expected": [
    { "kind": "active", "ts": 0 },
    { "kind": "idle", "ts": 0 }
  ],
  "expected_final": { "reported_state": "Idle" }
}
